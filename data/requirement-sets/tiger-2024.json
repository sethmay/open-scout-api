    {
      "number": "1",
      "text": "Required Adventures",
      "children": [
        {
          "number": "1",
          "text": "Bobcat Adventure",
          "children": [
            {
              "number": "1",
              "text": "Get to know the members of your den."
            },
            {
              "number": "2",
              "text": "Recite the Scout Oath with your den, including your Tiger adult partner."
            },
            {
              "number": "3",
              "text": "Have your Tiger adult partner or den leader read the Scout Law to you.  Demonstrate your understanding of being trustworthy, helpful, or friendly."
            },
            {
              "number": "4",
              "text": "Demonstrate the Cub Scout sign, Cub Scout salute and Cub Scout handshake.  Show how each are used."
            },
            {
              "number": "5",
              "text": "Share with your Tiger adult partner, at a den meeting or at home, a time when you have demonstrated the Cub Scout motto “Do Your Best.”"
            },
            {
              "number": "6",
              "text": "At home, with your parent or legal guardian do the activities in the booklet “ How to Protect Your Children from Child Abuse: A Parent’s Guide .”"
            }
          ]
