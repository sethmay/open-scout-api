    {
      "number": "1",
      "text": "Required Adventures",
      "children": [
        {
          "number": "1",
          "text": "Bobcat Adventure",
          "children": [
            {
              "number": "1",
              "text": "Demonstrate the patrol method by choosing a patrol name and electing a patrol leader. Discuss the benefits of using the patrol method."
            },
            {
              "number": "2",
              "text": "Get to know members of your patrol."
            },
            {
              "number": "3",
              "text": "Recite the Scout Oath and Scout Law with your patrol."
            },
            {
              "number": "4",
              "text": "With your patrol create a Code of Conduct."
            },
            {
              "number": "5",
              "text": "Demonstrate the Scout sign, Scout salute and Scout handshake used by Scouting America.  Show how each are used."
            },
            {
              "number": "6",
              "text": "Learn the Scouting America slogan and motto."
            },
            {
              "number": "7",
              "text": "With your patrol, or with your parent/legal guardian, visit a Scouting America troop."
            },
            {
              "number": "8",
              "text": "At home, with your parent or legal guardian do the activities in the booklet “How to Protect Your Children from Child Abuse: A Parent’s Guide.”"
            }
          ]
