{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sethmay.github.io/open-scout-api/schema/v1/published-current.schema.json",
  "title": "Open Scout API — published 'current' collection",
  "description": "Root schema for the denormalized, current-only consumer projections emitted by tools/build.py to v1/current/*.json (councils, territories, merit-badges, camps, ranks, awards, oa-lodges). NOT the canonical layer — flattened, current-only (entities with an open valid_to:null version; retired/defunct excluded), self-contained (no cross-file $ref). Fields are ADDITIVE-ONLY under v1 (a stable consumer contract): new optional fields may appear, but existing fields are not renamed or removed. Point a validator at any current/*.json file to validate it. (The lighter v1/{dataset}/index.json listings use a different, unschema'd item shape.)",
  "type": "object",
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "kind": { "enum": ["council", "territory", "merit-badge", "camp", "rank", "award", "oa-lodge"] },
    "count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": { "oneOf": [{ "$ref": "#/$defs/CurrentCouncil" }, { "$ref": "#/$defs/CurrentTerritory" }, { "$ref": "#/$defs/CurrentMeritBadge" }, { "$ref": "#/$defs/CurrentCamp" }, { "$ref": "#/$defs/CurrentRank" }, { "$ref": "#/$defs/CurrentAward" }, { "$ref": "#/$defs/CurrentOALodge" }] }
    }
  },
  "required": ["version", "generated_at", "kind", "count", "items"],
  "additionalProperties": false,
  "$defs": {
    "CurrentCouncil": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "bsa_number": { "type": ["integer", "null"], "minimum": 1 },
        "hq_city": { "type": ["string", "null"] },
        "hq_state": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
        "website": { "type": ["string", "null"], "format": "uri" },
        "territory": { "type": ["string", "null"], "pattern": "^territory:[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "territory_number": { "type": ["integer", "null"], "minimum": 1 },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "bsa_number", "hq_city", "hq_state", "website", "territory", "territory_number", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentTerritory": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "number": { "type": ["integer", "null"], "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "division_type": { "enum": ["council_service_territory", "national_service_territory", "region", "area"] },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "number", "name", "division_type", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentMeritBadge": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "eagle_required": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "url": { "type": ["string", "null"], "format": "uri" },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "eagle_required", "tags", "url", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentCamp": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "camp_type": { "type": "string" },
        "operator": { "enum": ["council", "national", "other", "unknown"] },
        "council": { "type": ["string", "null"], "pattern": "^council:[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "parent": { "type": ["string", "null"], "pattern": "^camp:[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "state": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
        "city": { "type": ["string", "null"] },
        "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "lon": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "website": { "type": ["string", "null"], "format": "uri" },
        "program_types": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": ["string", "null"] },
        "council_name": { "type": ["string", "null"] },
        "council_website": { "type": ["string", "null"], "format": "uri" },
        "council_number": { "type": ["integer", "null"], "minimum": 1 },
        "url": { "type": ["string", "null"], "format": "uri" },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "camp_type", "operator", "council", "parent", "council_name", "council_website", "council_number", "state", "city", "lat", "lon", "website", "url", "summary", "program_types", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentRank": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "program": { "type": "string" },
        "order": { "type": "integer", "minimum": 1 },
        "url": { "type": ["string", "null"], "format": "uri" },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "program", "order", "url", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentAward": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string" },
        "audience": { "enum": ["youth", "adult", "both"] },
        "programs": { "type": "array", "items": { "type": "string" } },
        "square_knot_no": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"], "format": "uri" },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "category", "audience", "square_knot_no", "verified_at", "method", "confidence"],
      "additionalProperties": false
    },
    "CurrentOALodge": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "council": { "type": ["string", "null"] },
        "section": { "type": ["string", "null"] },
        "hq_state": { "type": ["string", "null"] },
        "lat": { "type": ["number", "null"] },
        "lon": { "type": ["number", "null"] },
        "verified_at": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "council", "section", "verified_at", "method", "confidence"],
      "additionalProperties": false
    }
  }
}
