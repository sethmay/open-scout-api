{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sethmay.github.io/open-scout-api/schema/v1/published-current.schema.json",
  "title": "Open Scout API — published 'current' projections",
  "description": "Schema for the denormalized consumer projections emitted by tools/build.py to v1/current/*.json. These are NOT the canonical layer — they are flattened, current-only (entities with an open valid_to:null version), and self-contained (no cross-file $ref). Retired/defunct entities are excluded. The build validates its output against these to keep the consumer contract honest.",
  "$defs": {
    "CurrentCouncil": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "name": { "type": "string", "minLength": 1 },
        "bsa_number": { "type": ["integer", "null"], "minimum": 1 },
        "hq_city": { "type": ["string", "null"] },
        "hq_state": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
        "website": { "type": ["string", "null"], "format": "uri" },
        "territory": { "type": ["string", "null"], "pattern": "^territory:[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "territory_number": { "type": ["integer", "null"], "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "name", "bsa_number", "hq_city", "hq_state", "website", "territory", "territory_number", "confidence"],
      "additionalProperties": false
    },
    "CurrentTerritory": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$" },
        "number": { "type": ["integer", "null"], "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "division_type": { "enum": ["council_service_territory", "national_service_territory", "region", "area"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["id", "number", "name", "division_type", "confidence"],
      "additionalProperties": false
    },
    "Collection": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "kind": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "items": { "type": "array" }
      },
      "required": ["version", "generated_at", "kind", "count", "items"],
      "additionalProperties": false
    }
  }
}
